---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);
---

<BaseLayout title="Blog" description="My personal blog">
  <Header />
  <main class="home">
    <section class="hero">
      <h1>Hey, I'm <span class="highlight">Avishek</span></h1>
      <p>Welcome to my corner of the internet. I write about technology, learning, and projects I'm working on.</p>
    </section>

    <section class="posts">
      <h2>Recent Posts</h2>
      <div class="post-list">
        {posts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.id.replace(/\.md$/, '')}
            tags={post.data.tags}
          />
        ))}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .home {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 1.5rem;
    flex: 1;
  }

  .hero {
    padding: 3rem 0 2rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 0.8rem;
    line-height: 1.2;
  }

  .highlight {
    color: var(--accent);
  }

  .hero p {
    color: var(--text-secondary);
    font-size: 1.15rem;
    max-width: 500px;
    line-height: 1.6;
  }

  .posts {
    padding: 2rem 0;
  }

  .posts h2 {
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 1.2rem;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
</style>
